<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXSlider?>
<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="380.0" prefWidth="500.0"
            style="-fx-background-color: #f1f1f1;"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FXML_Controllers.Settings">
    <children>


        <Label layoutX="0.0" layoutY="18.0"
               prefWidth="500.0"
               alignment="CENTER"
               text="Settings"
               textFill="#0a0a6e"
               style="-fx-alignment: center;">
            <font>
                <Font name="Berlin Sans FB Demi Bold" size="30.0" />
            </font>
        </Label>


        <Line startX="30.0" endX="470.0"
              layoutX="0.0" layoutY="62.0"
              stroke="#0a0a6e" strokeWidth="1.5" />

        <!-- ===================================================== -->
        <!-- SECTION 1: BACKGROUND MUSIC VOLUME                    -->
        <!-- ===================================================== -->
        <Label layoutX="30.0" layoutY="78.0"
               text="🎵  Background Music Volume"
               textFill="#333333">
            <font>
                <Font name="Berlin Sans FB" size="16.0" />
            </font>
        </Label>


        <JFXSlider fx:id="slider_music"
                   layoutX="30.0" layoutY="110.0"
                   prefWidth="340.0"
                   min="0" max="100" value="50"
                   onMouseDragged="#onMusicVolumeDragged"
                   onMouseReleased="#onMusicVolumeChanged" />


        <Label fx:id="label_music_value"
               layoutX="385.0" layoutY="105.0"
               prefWidth="60.0"
               text="50%"
               textFill="#555555">
            <font>
                <Font name="Berlin Sans FB" size="15.0" />
            </font>
        </Label>


        <Label layoutX="30.0" layoutY="155.0"
               text="🔊  Sound Effects Volume"
               textFill="#333333">
            <font>
                <Font name="Berlin Sans FB" size="16.0" />
            </font>
        </Label>

        <JFXSlider fx:id="slider_sfx"
                   layoutX="30.0" layoutY="187.0"
                   prefWidth="340.0"
                   min="0" max="100" value="100"
                   onMouseDragged="#onSFXVolumeDragged"
                   onMouseReleased="#onSFXVolumeChanged" />

        <Label fx:id="label_sfx_value"
               layoutX="385.0" layoutY="182.0"
               prefWidth="60.0"
               text="100%"
               textFill="#555555">
            <font>
                <Font name="Berlin Sans FB" size="15.0" />
            </font>
        </Label>


        <Label layoutX="30.0" layoutY="232.0"
               text="👤  Your Player Name"
               textFill="#333333">
            <font>
                <Font name="Berlin Sans FB" size="16.0" />
            </font>
        </Label>

        <JFXTextField fx:id="textfield_player_name"
                      layoutX="30.0" layoutY="260.0"
                      prefHeight="38.0" prefWidth="440.0"
                      promptText="Enter your name..."
                      focusColor="#0a0a6e"
                      unFocusColor="#aaaaaa">
            <font>
                <Font name="Berlin Sans FB" size="16.0" />
            </font>
        </JFXTextField>


        <Line startX="30.0" endX="470.0"
              layoutX="0.0" layoutY="320.0"
              stroke="#0a0a6e" strokeWidth="1.5" />


        <Button fx:id="button_save"
                layoutX="100.0" layoutY="333.0"
                prefHeight="38.0" prefWidth="120.0"
                text="SAVE"
                mnemonicParsing="false"
                textAlignment="CENTER"
                onMouseClicked="#ClickedOnSave"
                onMouseEntered="#MouseEnteredOnSave">
            <font>
                <Font name="HYSinMyeongJo-Medium" size="16.0" />
            </font>
        </Button>


        <Button fx:id="button_close"
                layoutX="280.0" layoutY="333.0"
                prefHeight="38.0" prefWidth="120.0"
                text="CLOSE"
                mnemonicParsing="false"
                textAlignment="CENTER"
                onMouseClicked="#ClickedOnClose"
                onMouseEntered="#MouseEnteredOnClose">
            <font>
                <Font name="HYSinMyeongJo-Medium" size="16.0" />
            </font>
        </Button>

    </children>
</AnchorPane>
