<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FXML_Controllers.FirstPage">
    <children>

        <ImageView fitHeight="700.0" fitWidth="600.0"
                   layoutX="0.0" layoutY="0.0"
                   pickOnBounds="true"
                   preserveRatio="false">
            <image>
                <Image url="@../images/Background1Login.png" />
            </image>
        </ImageView>


        <AnchorPane fx:id="Center_AnchorPane"
                    layoutX="180.0" layoutY="400.0"
                    prefHeight="250.0" prefWidth="240.0"
                    style="-fx-background-color: transparent;">
            <children>


                <Button fx:id="button_start"
                        layoutX="0.0" layoutY="0.0"
                        prefHeight="36.0" prefWidth="240.0"
                        text="START"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#clicked_Start"
                        onMouseEntered="#MouseEnteredOnStart"
                        onMouseExited="#MouseExitedOnStart">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>


                <Button fx:id="button_join"
                        layoutX="0.0" layoutY="44.0"
                        prefHeight="36.0" prefWidth="240.0"
                        text="JOIN GAME"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#ClickedOnJoin"
                        onMouseEntered="#MouseEnteredOnJoin">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>


                <Button fx:id="button_settings"
                        layoutX="0.0" layoutY="88.0"
                        prefHeight="36.0" prefWidth="240.0"
                        text="SETTINGS"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#ClickedOnSettings"
                        onMouseEntered="#MouseEnteredOnSettings">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>


                <Button fx:id="button_help"
                        layoutX="0.0" layoutY="132.0"
                        prefHeight="36.0" prefWidth="240.0"
                        text="HELP"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#ClickedOnHelp"
                        onMouseEntered="#MouseEnteredOnHelp">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>


                <Button fx:id="button_about"
                        layoutX="0.0" layoutY="176.0"
                        prefHeight="36.0" prefWidth="240.0"
                        text="ABOUT US"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#ClickedOnAbout"
                        onMouseEntered="#MouseEnteredOnAbout">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>


                <Button fx:id="button_exit"
                        layoutX="0.0" layoutY="220.0"
                        prefHeight="36.0" prefWidth="240.0"
                        text="EXIT"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#clicked_Exit"
                        onMouseEntered="#MouseEnteredOnExit">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>

            </children>
        </AnchorPane>


        <AnchorPane fx:id="AnchorPane_start"
                    prefHeight="706.0" prefWidth="603.0"
                    visible="false">
            <children>

                <ImageView fx:id="image_body"
                           fitHeight="580.0" fitWidth="498.0"
                           layoutX="53.0" layoutY="82.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/Body Png.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="image_header"
                           fitHeight="580.0" fitWidth="498.0"
                           layoutX="53.0" layoutY="82.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/Header Png.png" />
                    </image>
                </ImageView>


                <Button fx:id="button_back"
                        layoutX="169.0" layoutY="433.0"
                        prefHeight="54.0" prefWidth="121.0"
                        text="BACK"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#Clicked_On_Back"
                        onMouseEntered="#MouseEntred_Back_Button">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="18.0" />
                    </font>
                </Button>


                <Button fx:id="button_new"
                        layoutX="321.0" layoutY="433.0"
                        prefHeight="54.0" prefWidth="121.0"
                        text="NEW GAME"
                        mnemonicParsing="false"
                        textAlignment="CENTER"
                        onMouseClicked="#ClickedOnnew"
                        onMouseEntered="#MouseEntred_New_Button">
                    <font>
                        <Font name="HYSinMyeongJo-Medium" size="16.0" />
                    </font>
                </Button>


                <ImageView fx:id="image_bar_select_player"
                           fitHeight="77.0" fitWidth="325.0"
                           layoutX="148.0" layoutY="276.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/bat number of players 2.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="image_number_of_players"
                           fitHeight="77.0" fitWidth="280.0"
                           layoutX="162.0" layoutY="217.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/number of players 6.png" />
                    </image>
                </ImageView>


                <ImageView fx:id="image_select_1" fitHeight="22.0" fitWidth="9.0" layoutX="164.0" layoutY="304.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                </ImageView>
                <ImageView fx:id="image_select_2" fitHeight="22.0" fitWidth="9.0" layoutX="197.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_2" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>
                <ImageView fx:id="image_select_3" fitHeight="22.0" fitWidth="9.0" layoutX="238.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_3" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>
                <ImageView fx:id="image_select_4" fitHeight="22.0" fitWidth="9.0" layoutX="278.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_4" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>
                <ImageView fx:id="image_select_5" fitHeight="22.0" fitWidth="9.0" layoutX="316.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_5" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>
                <ImageView fx:id="image_select_6" fitHeight="22.0" fitWidth="9.0" layoutX="356.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_6" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>
                <ImageView fx:id="image_select_7" fitHeight="22.0" fitWidth="9.0" layoutX="392.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_7" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>
                <ImageView fx:id="image_select_8" fitHeight="22.0" fitWidth="9.0" layoutX="426.0" layoutY="304.0" onMouseClicked="#mouse_clickOn_8" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../images/test7.png" /></image>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </ImageView>

                <ImageView fx:id="image_triangle"
                           fitHeight="31.0" fitWidth="41.0"
                           layoutX="187.0" layoutY="272.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/triangle.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="image_amount_label"
                           fitHeight="57.0" fitWidth="140.0"
                           layoutX="142.0" layoutY="366.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/amount.png" />
                    </image>
                </ImageView>

                <JFXTextField fx:id="textfield_amount"
                              alignment="CENTER"
                              focusColor="#d3620c"
                              layoutX="283.0" layoutY="360.0"
                              prefHeight="44.0" prefWidth="150.0"
                              unFocusColor="#cf5108">
                    <font>
                        <Font name="Century Gothic Italic" size="21.0" />
                    </font>
                </JFXTextField>

                <ImageView fx:id="image_dollar_symbole"
                           fitHeight="31.0" fitWidth="71.0"
                           layoutX="418.0" layoutY="379.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/dollar.png" />
                    </image>
                </ImageView>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>
